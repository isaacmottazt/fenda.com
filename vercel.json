{
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/login",
      "destination": "/index.html"
    },
    {
      "source": "/inicio",
      "destination": "/player.html"
    },
    {
      "source": "/busca",
      "destination": "/player.html"
    },
    {
      "source": "/biblioteca",
      "destination": "/player.html"
    },
    {
      "source": "/biblioteca/playlists",
      "destination": "/player.html"
    },
    {
      "source": "/biblioteca/historico",
      "destination": "/player.html"
    },
    {
      "source": "/biblioteca/artistas",
      "destination": "/player.html"
    },
    {
      "source": "/biblioteca/downloads",
      "destination": "/player.html"
    },
    {
      "source": "/biblioteca/playlist/:id",
      "destination": "/player.html"
    },
    {
      "source": "/biblioteca/artista/:nome",
      "destination": "/player.html"
    },
    {
      "source": "/perfil",
      "destination": "/player.html"
    },
    {
      "source": "/reset-password",
      "destination": "/reset-password.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}